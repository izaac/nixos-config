#!/usr/bin/env bash

# Fail immediately if any command returns a non-zero exit status.
# This prevents the hook from failing silently and allowing a bad commit.
set -e 

# Redirect output to stderr so it shows up in git console output properly.
exec 1>&2

echo "Running Pre-Commit Hooks..."

# Get staged nix files. '|| true' prevents set -e from killing the script if grep finds nothing.
STAGED_NIX_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.nix$' || true)

if [ -n "$STAGED_NIX_FILES" ]; then
    echo "Formatting with alejandra..."
    nix run nixpkgs#alejandra -- -q $STAGED_NIX_FILES
    
    echo "Checking for dead code..."
    nix run nixpkgs#deadnix -- -e $STAGED_NIX_FILES
    
    echo "Running statix checks..."
    # Iterate through files individually for statix
    for file in $STAGED_NIX_FILES; do
        echo " -> statix fix $file"
        nix run nixpkgs#statix -- fix "$file"
    done

    # Re-stage files because the tools above modify them in place
    git add $STAGED_NIX_FILES
fi

echo "Pre-Commit Checks Passed!"
exit 0
